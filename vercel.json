{
  "redirects": [
    { "source": "/blog/:slug((?!.*\\.html$)[a-z0-9-]+)", "destination": "/blog/:slug.html", "statusCode": 301 },
    { "source": "/combine/combo/", "destination": "/combine/combo", "statusCode": 301 },
    { "source": "/combine/", "destination": "/combine", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/prospects", "destination": "/prospects.html" },
    { "source": "/team-needs", "destination": "/team-needs.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/combine/combo", "destination": "/combine.html" },
    { "source": "/combine", "destination": "/combine.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
